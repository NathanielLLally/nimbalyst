# ============================================================================
# Vapi Contact Tracker Configuration
# ============================================================================

# Google Sheets API credentials
GOOGLE_SHEET_ID=your-sheet-id-here
GOOGLE_API_KEY=your-google-api-key-here

# Vapi API credentials
VAPI_API_KEY=your-vapi-api-key-here
VAPI_PHONE_NUMBER_ID=your-vapi-phone-number-id
VAPI_ASSISTANT_ID=your-vapi-assistant-id

# Tracker configuration
# Retry delays in minutes (0-indexed array): attempt 1, attempt 2, attempt 3, attempt 4
RETRY_DELAYS_MINUTES=[0,5,15,60]

# Maximum number of retry attempts (including initial attempt)
MAX_ATTEMPTS=4

# How often to poll Vapi for status updates (seconds)
# Set to 0 to disable polling (use webhooks instead)
POLL_INTERVAL_SECONDS=30

# Google Sheet name (default: "Sheet1")
SHEET_NAME=Sheet1

# ============================================================================
# Vapi Webhook Configuration (Optional - for real-time call updates)
# ============================================================================

# Optional: Sheet name for detailed call logs
# If set, each completed call will be logged with transcript, summary, etc.
# VAPI_CALL_DETAILS_SHEET=Call Details

# Optional: Webhook signature verification
# Get this from Vapi dashboard when you create the webhook
# VAPI_WEBHOOK_SECRET=whsec_your_secret_here

# ============================================================================
# Google Sheets API Setup Instructions
# ============================================================================
# 1. Go to https://console.cloud.google.com
# 2. Create a new project
# 3. Enable "Google Sheets API"
# 4. Create an "API Key" credential (not OAuth)
# 5. Paste the key here as GOOGLE_API_KEY
# 6. Create a Google Sheet with headers:
#    ID | Phone | Name | Channel | Status | Attempt Count |
#    Submitted | Last Attempt | Next Retry | Resolved | Vapi Call ID | Notes
# 7. Copy the sheet ID from the URL
#
# ============================================================================
# Vapi Setup Instructions
# ============================================================================
# 1. Go to https://dashboard.vapi.ai
# 2. Settings → API Keys → Create or copy your API key
# 3. Phone Numbers → Select your number → Copy the ID
# 4. Assistants → Create or select an assistant → Copy the ID
# 5. In the assistant, add these variables:
#    - customerName (string)
#    - channel (string: "voice" or "sms")
# 6. (Optional) Set up webhook in Assistant → Webhooks
#    URL: Your /api/vapi-track endpoint
#    Event: call.ended
